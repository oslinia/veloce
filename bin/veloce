#!/usr/bin/env php
<?php

declare(strict_types=1);

/**
 * Veloce Framework CLI Build Tool
 * Usage: php bin/veloce
 */

$root = dirname(__DIR__);

// Проверка наличия автозагрузчика перед запуском
if (!is_file($root . '/vendor/autoload.php')) {
    echo "\033[1;31m❌ Error: vendor/autoload.php not found.\033[0m\n";
    echo "Please run 'composer install' first.\n";
    exit(1);
}

require $root . '/vendor/autoload.php';

use Veloce\Resource\Cache;

echo "\033[1;34m--- Veloce Build Tool ---\033[0m\n\n";

try {
    $start = microtime(true);

    echo "⚙️  Building application infrastructure...\n";

    // Инициализация кэша, путей и окружения
    new Cache($root, force: true);

    $time = round((microtime(true) - $start) * 1000, 2);

    echo "\n\033[1;32m✅ Success!\033[0m\n";
    echo "📦 Cache recompiled in \033[1;33m{$time}ms\033[0m\n";
    echo "📂 Location: resource/cache/\n";
    echo "📂 Logs:     logs/\n";
} catch (\Throwable $e) {
    echo "\n\033[1;31m❌ Build Failed:\033[0m\n";
    echo "   " . $e->getMessage() . "\n";
    echo "   In " . $e->getFile() . ":" . $e->getLine() . "\n";
    exit(1);
}
